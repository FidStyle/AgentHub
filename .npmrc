shamefully-hoist=false
strict-peer-dependencies=false
electron_mirror=https://npmmirror.com/mirrors/electron/

# Keep React typings out of the hoisted virtual-store root (node_modules/.pnpm/node_modules).
# Mobile pins @types/react@18 while web/ui/desktop use @types/react@19; if either copy gets
# hoisted, TypeScript's ambient @types discovery leaks the wrong ReactNode/ReactPortal into
# every package's compile graph. Each workspace still resolves its own version via its direct
# dependency symlink, so isolation is preserved without skipLibCheck or casts.
hoist-pattern[]=*
hoist-pattern[]=!@types/react
hoist-pattern[]=!@types/react-dom

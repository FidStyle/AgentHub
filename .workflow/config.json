{
  "workflow": {
    "research": true,
    "reflection": true
  },
  "execution": {
    "method": "auto",
    "auto_commit": true,
    "default_executor": ""
  },
  "git": {
    "commit_docs": true
  },
  "gates": {
    "confirm_roadmap": true,
    "confirm_plan": true
  },
  "codebase": {
    "auto_sync_after_execute": true
  },
  "guard": {
    "enabled": false,
    "mode": "allow",
    "paths": []
  },
  "collab": {
    "preflight_mode": "warn",
    "preflight_window_min": 30,
    "auto_preflight": true
  },
  "specInjection": {
    "always": {
      "keywords": [
        "wave",
        "跟进",
        "tracker",
        "commit",
        "ui",
        "playwright",
        "governance",
        "e2e",
        "visual",
        "gate",
        "治理门禁",
        "status.json"
      ],
      "categories": [
        "coding",
        "test",
        "review",
        "arch"
      ],
      "docs": [
        "research/index.md",
        "research/workflow/maestro-guidance-playbook.md",
        "research/project-tracker.md",
        "research/decision-log.md",
        "research/product/ui-design-system.md",
        "research/workflow/maestro-execution-governance.md"
      ]
    },
    "categoryDocs": {
      "ui": {
        "docs": [
          "research/product/ui-design-system.md",
          "research/product/product-design.md",
          "research/product/desktop-p0-ui-ux-contract.md"
        ]
      },
      "test": {
        "docs": [
          "research/maestro-tdd-quality-gates.md",
          "research/modules/ui-and-visual-testing.md"
        ]
      }
    }
  },
  "dashboard": {
    "port": 3001
  },
  "worktree": {
    "root": ".worktrees",
    "branch_prefix": "milestone/"
  }
}
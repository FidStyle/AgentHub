{
  "name": "agenthub",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev:web": "pnpm --filter @agenthub/web dev",
    "dev:desktop": "pnpm --filter @agenthub/desktop exec concurrently -k -n web,desktop \"pnpm --filter @agenthub/web dev\" \"wait-on http://localhost:3000 && pnpm --filter @agenthub/desktop dev:app\"",
    "env:p0:db:up": "docker compose -f docker/docker-compose.p0-test.yml up -d postgres",
    "env:p0:db:down": "docker compose -f docker/docker-compose.p0-test.yml down",
    "env:p0:seed": "pnpm --filter @agenthub/web exec tsx scripts/setup-p0-test-db.ts",
    "env:p0:seed:fixture": "P0_CREATE_GITHUB_FIXTURE=true pnpm env:p0:seed",
    "env:p0:smoke": "set -a; . docker/.p0-test.env; set +a; pnpm --filter @agenthub/web exec tsx scripts/verify-p0-api-crud.ts",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:e2e": "npx playwright test --config e2e/playwright.config.ts",
    "test:e2e:desktop": "npx playwright test --config e2e/playwright.desktop.config.ts",
    "lint": "pnpm -r lint",
    "type-check": "pnpm -r type-check"
  },
  "dependencies": {
    "react-markdown": "^9.0.0",
    "rehype-highlight": "^7.0.0",
    "remark-gfm": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.60.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  }
}

{
  "name": "@agenthub/desktop",
  "version": "0.0.1",
  "private": true,
  "main": "dist/main/main/index.js",
  "scripts": {
    "dev": "pnpm dev:app",
    "dev:app": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build && tsc -p tsconfig.main.json",
    "type-check": "tsc --noEmit -p tsconfig.main.json && tsc --noEmit",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@agenthub/shared": "workspace:*",
    "@agenthub/ui": "workspace:*",
    "lucide-react": "^0.468.0",
    "ws": "^8.18.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.5.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "electron": "^33.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "wait-on": "^8.0.0"
  }
}

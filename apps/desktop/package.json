{
  "name": "@agenthub/desktop",
  "version": "0.0.1",
  "private": true,
  "main": "dist/main/main/index.js",
  "scripts": {
    "dev": "pnpm dev:app",
    "dev:app": "concurrently -k \"vite\" \"tsc -p tsconfig.main.json && wait-on tcp:5173 && electron .\"",
    "build": "pnpm --filter @agenthub/shared build && vite build && tsc -p tsconfig.main.json",
    "dist": "pnpm build && electron-builder",
    "dist:mac": "pnpm build && electron-builder --mac --dir",
    "dist:mac:dmg": "pnpm build && electron-builder --mac dmg",
    "type-check": "tsc --noEmit -p tsconfig.main.json && tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run"
  },
  "dependencies": {
    "@agenthub/shared": "workspace:*",
    "@agenthub/ui": "workspace:*",
    "lucide-react": "^0.468.0",
    "ws": "^8.18.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.5.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^26.8.1",
    "jsdom": "^25.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0",
    "wait-on": "^8.0.0"
  }
}

# Auth.js v5
AUTH_SECRET=your-auth-secret-generate-with-npx-auth-secret
AUTH_GITHUB_ID=your-github-oauth-app-client-id
AUTH_GITHUB_SECRET=your-github-oauth-app-client-secret

# Database (local Postgres for dev, Supabase Postgres for prod)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agenthub

# Supabase (DB queries + Realtime only, NOT auth)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

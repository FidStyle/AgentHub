{
  "name": "@agenthub/web",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "WATCHPACK_POLLING=true tsx server.ts",
    "dev:next": "WATCHPACK_POLLING=true next dev --port 3000",
    "build": "next build",
    "start": "NODE_ENV=production tsx server.ts",
    "test": "vitest run",
    "test:integration": "RUN_DB_INTEGRATION=1 vitest run __tests__/integration",
    "type-check": "tsc --noEmit",
    "lint": "next lint"
  },
  "dependencies": {
    "@agenthub/shared": "workspace:*",
    "@agenthub/ui": "workspace:*",
    "@auth/drizzle-adapter": "^1.11.2",
    "drizzle-orm": "^0.45.2",
    "katex": "^0.17.0",
    "lucide-react": "^0.468.0",
    "next": "^15.1.0",
    "next-auth": "5.0.0-beta.31",
    "pg": "^8.21.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "redis": "^4.7.1",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0",
    "streamdown": "^2.5.0",
    "undici": "^8.3.0",
    "ws": "^8.18.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.5.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
